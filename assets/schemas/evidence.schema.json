{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "evidence.schema.json",
  "title": "EvidenceBundle",
  "description": "Evidence bundle emitted by the evidence_collector skill.",
  "type": "object",
  "required": ["game", "current_data", "authoritative_docs", "degradation_level"],
  "additionalProperties": true,
  "properties": {
    "game": {"type": "string"},
    "target_item": {"type": "string"},
    "current_data": {
      "type": "object",
      "properties": {
        "belts": {"type": "object"},
        "machines": {"type": "object"},
        "modules": {"type": "object"},
        "recipes": {"type": "array"}
      }
    },
    "authoritative_docs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "tier"],
        "properties": {
          "title": {"type": "string"},
          "venue": {"type": "string"},
          "doi": {"type": "string"},
          "tier": {"type": "string"}
        }
      }
    },
    "recent_news": {"type": "array"},
    "reference_benchmarks": {"type": "string"},
    "degradation_level": {"type": "integer", "minimum": 0, "maximum": 4},
    "limitations": {"type": "array", "items": {"type": "string"}}
  }
}